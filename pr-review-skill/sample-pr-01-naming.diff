+/**
+ * Apply discount based on risk band and threshold.
+ */
+function calc(r, cfg) {
+  const thr = cfg.t ?? 50;
+  const mult = r.band === "high" ? 1.0 : 0.9;
+  if (r.v > thr) {
+    return r.v * cfg.m * mult;
+  }
+  return r.v * 0.9;
 }

 module.exports = { calc };
